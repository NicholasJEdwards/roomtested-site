---
import JsonLd from '../../components/JsonLd.astro';
import KeySpecs from '../../components/KeySpecs.astro';
import ProductMedia from '../../components/ProductMedia.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { CATEGORIES } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbsLd, productLd } from '../../lib/jsonld';
import { getArticlesForProduct } from '../../lib/links';
import {
  gbp,
  getAllProducts,
  goHref,
  resolveTarget,
  STORE_LABELS,
  type Store,
} from '../../lib/products';

export async function getStaticPaths() {
  return getAllProducts().map((product) => ({ params: { id: product.id }, props: { product } }));
}

const { product } = Astro.props;
const url = `/products/${product.id}`;

const category = CATEGORIES.find((c) => c.slug === product.category);
const categoryName = category?.name ?? product.category.replace(/-/g, ' ');

// Image honesty: a stored image is a manufacturer/store listing image unless we know it's
// our own (no 'own' photos are wired into products.json yet → 'listing'). With no image,
// ProductMedia renders the clean placeholder and makes NO provenance claim.
const mediaKind = product.image ? ('listing' as const) : ('own' as const);

// specs (Record) → KeySpecs rows.
const keySpecs =
  product.specs && Object.keys(product.specs).length > 0
    ? Object.entries(product.specs).map(([label, value]) => ({
        label: label.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
        value: typeof value === 'boolean' ? (value ? 'Yes' : 'No') : String(value),
      }))
    : undefined;

// Variants worth showing (skip the empty single-variant placeholder).
const variants = (product.variants ?? []).filter((v) => v.label.trim().length > 0);

// Buy box: primary store (+ a "compare" store if a second link exists).
const storeKeys = Object.keys(product.links) as Store[];
const primaryStore: Store | undefined = storeKeys[0];
const compareStore: Store | undefined = storeKeys.find((s) => s !== primaryStore);
const ctaAvailable = !!(primaryStore && resolveTarget(product, primaryStore));
const compareAvailable = !!(compareStore && resolveTarget(product, compareStore));

const checkedOn = product.priceCheckedAt
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
      .format(new Date(product.priceCheckedAt))
      .toUpperCase()
  : null;

const mentions = await getArticlesForProduct(product.id);
// Pink chip per mention: full review / winner / ranked / compared / guide.
const mentionEntries = mentions.map((m) => {
  let tag: string | undefined;
  if (m.kind === 'review') tag = 'Full review';
  else if (m.kind === 'comparison') tag = 'Compared';
  else if (m.kind === 'guide') tag = 'Featured';
  return { ...m, tag };
});
---

<BaseLayout
  title={product.name}
  description={`${product.name} — price, specs and the RoomTested articles that mention it.`}
  ogType="website"
  ogImage={product.image}
>
  <JsonLd
    data={[
      productLd({
        name: product.name,
        brand: product.brand,
        image: product.image,
        url,
        priceFromGBP: product.priceFromGBP,
        priceCheckedAt: product.priceCheckedAt,
      }),
      breadcrumbsLd([
        { name: 'Home', href: '/' },
        { name: categoryName, href: `/c/${product.category}` },
        { name: product.name, href: url },
      ]),
    ]}
  />

  <div class="py-10">
    <nav class="font-data text-xs uppercase tracking-[0.05em] text-sepia-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink-900">Home</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href={`/c/${product.category}`} class="hover:text-ink-900">{categoryName}</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span class="text-umber-600">{product.name}</span>
    </nav>

    <!-- Two-column hero: gallery (left) + buy box (right) -->
    <div class="mt-5 grid gap-10 lg:grid-cols-[1fr_420px]">
      <!-- Gallery -->
      <div class="flex flex-col gap-3">
        <ProductMedia
          kind={mediaKind}
          src={product.image}
          alt={product.name}
          ratio="3/2"
          priority
          glyph="text-[96px]"
          rounded="rounded-xl"
          class="my-0"
        />
        {product.image && (
          <div class="flex gap-2.5">
            <div class="h-16 w-20 shrink-0 overflow-hidden rounded-md border-2 border-terracotta-600 bg-cream-200">
              <img src={product.image} alt="" loading="lazy" class="h-full w-full object-cover" />
            </div>
          </div>
        )}
        <p class="font-body text-[13px] leading-[1.5] text-sepia-400">
          {product.image
            ? 'Image is the manufacturer listing image, not our own bench photo.'
            : 'No bench photo on file yet — a clean placeholder, never a borrowed image passed off as our own.'}
        </p>
      </div>

      <!-- Buy box -->
      <div class="flex flex-col gap-4">
        <div class="font-data text-[12px] font-medium uppercase tracking-[0.12em] text-terracotta-600">
          {categoryName}{product.brand ? ` · ${product.brand}` : ''}
        </div>
        <h1 class="font-display text-[26px] font-semibold leading-[1.22] tracking-tight text-ink-900 sm:text-[30px]">{product.name}</h1>

        <div class="rounded-xl border border-sepia-200 bg-cream-100 p-5">
          <div class="flex items-center gap-3">
            <div class="flex flex-col gap-0.5">
              <span class="font-display text-[34px] font-bold tabular-nums leading-none text-ink-900">
                {product.priceFromGBP !== undefined ? `from ${gbp.format(product.priceFromGBP)}` : 'Price varies'}
              </span>
              {primaryStore && (
                <span class="font-data text-[10px] font-medium uppercase tracking-[0.1em] text-umber-600">
                  On {STORE_LABELS[primaryStore]}
                </span>
              )}
            </div>
            {ctaAvailable && (
              <span class="ml-auto inline-flex items-center gap-1.5 rounded-full bg-[#3e8a64] py-1 pl-2.5 pr-3">
                <span class="h-1.5 w-1.5 rounded-full bg-white" aria-hidden="true"></span>
                <span class="font-data text-[9px] font-bold uppercase tracking-[0.05em] text-white">In stock</span>
              </span>
            )}
          </div>

          {ctaAvailable && primaryStore && (
            <a
              href={goHref(product.id, primaryStore)}
              rel="sponsored nofollow noopener"
              target="_blank"
              aria-label={`Buy ${product.name} on ${STORE_LABELS[primaryStore]} — opens in new tab`}
              class="mt-3.5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-terracotta-600 px-5 py-3.5 font-body text-base font-bold text-white transition-colors hover:bg-terracotta-700"
            >
              <span>Buy on {STORE_LABELS[primaryStore]}</span>
              <span aria-hidden="true">&rarr;</span>
            </a>
          )}

          {compareAvailable && compareStore ? (
            <a
              href={goHref(product.id, compareStore)}
              rel="sponsored nofollow noopener"
              target="_blank"
              aria-label={`Compare ${product.name} on ${STORE_LABELS[compareStore]} UK — opens in new tab`}
              class="mt-2.5 inline-flex w-full items-center justify-center rounded-lg border-[1.5px] border-ink-900 bg-white px-5 py-3.5 font-body text-base font-bold text-ink-900 transition-colors hover:bg-cream-100"
            >
              Compare on {STORE_LABELS[compareStore]} UK
            </a>
          ) : (
            <a
              href={`https://www.ebay.co.uk/sch/i.html?_nkw=${encodeURIComponent(product.name)}`}
              rel="nofollow noopener"
              target="_blank"
              aria-label={`Compare ${product.name} on eBay UK — opens in new tab`}
              class="mt-2.5 inline-flex w-full items-center justify-center rounded-lg border-[1.5px] border-ink-900 bg-white px-5 py-3.5 font-body text-base font-bold text-ink-900 transition-colors hover:bg-cream-100"
            >
              Compare on eBay UK
            </a>
          )}

          <p class="mt-2.5 font-data text-[10px] leading-normal tracking-[0.02em] text-sepia-400">
            {checkedOn && <>PRICE CHECKED {checkedOn} · </>}We may earn from qualifying purchases.
          </p>
        </div>
      </div>
    </div>

    <!-- Variants + Specifications -->
    {(variants.length > 0 || keySpecs) && (
      <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_480px]">
        {variants.length > 0 ? (
          <section aria-label="Variants">
            <div class="font-data text-[12px] font-bold uppercase tracking-[0.14em] text-umber-600">Variants</div>
            <div class="mt-3.5 flex flex-wrap gap-2.5">
              {variants.map((v, i) => (
                <div
                  class:list={[
                    'flex flex-col gap-0.5 rounded-lg px-4 py-3',
                    i === 0 ? 'border-2 border-terracotta-600 bg-cream-100' : 'border border-sepia-200 bg-white',
                  ]}
                >
                  <span class="font-body text-[15px] font-semibold text-ink-900">{v.label}</span>
                  <span class="font-data text-[13px] font-bold text-umber-600">
                    {v.orig !== undefined ? gbp.format(v.orig) : '—'}
                  </span>
                </div>
              ))}
            </div>
            <p class="mt-3 font-body text-[13px] leading-[1.48] text-sepia-400">
              Prices are the standard listing price (not new-user promo){checkedOn ? `, checked ${checkedOn.toLowerCase()}` : ''}.
            </p>
          </section>
        ) : (
          <div></div>
        )}
        <KeySpecs specs={keySpecs} title="Specifications" />
      </div>
    )}

    <!-- Reviewed & mentioned in -->
    {mentionEntries.length > 0 ? (
      <div class="mt-10 rounded-xl bg-cream-100 px-6 py-8">
        <RelatedArticles entries={mentionEntries} title="Reviewed & mentioned in" kicker />
      </div>
    ) : (
      <section class="mt-10" aria-label="Reviewed and mentioned in">
        <h2 class="font-data text-xs font-bold uppercase tracking-[0.14em] text-terracotta-600">Reviewed &amp; mentioned in</h2>
        <p class="mt-3 font-body text-sm text-umber-600">No published articles mention this product yet — a test may be running.</p>
      </section>
    )}
  </div>
</BaseLayout>
