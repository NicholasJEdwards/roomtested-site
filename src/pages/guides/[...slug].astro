---
import { getCollection, render } from 'astro:content';

import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import JsonLd from '../../components/JsonLd.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articleLd, breadcrumbsLd } from '../../lib/jsonld';
import { mdxComponents } from '../../lib/mdx-components';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (e) => !e.data.draft || import.meta.env.DEV);
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const d = guide.data;
const ogImage = `/cards/guides/${guide.id}/og.png`;
---

<BaseLayout title={d.title} description={d.description} ogType="article" ogImage={ogImage}>
  <JsonLd
    data={[
      articleLd({
        title: d.title,
        description: d.description,
        url: `/guides/${guide.id}`,
        publishedAt: d.publishedAt,
        updatedAt: d.updatedAt,
        author: d.author,
        image: ogImage,
      }),
      breadcrumbsLd([
        { name: 'Home', href: '/' },
        { name: 'Guides', href: '/guides' },
        { name: d.title, href: `/guides/${guide.id}` },
      ]),
    ]}
  />
  <article class="mx-auto max-w-3xl py-12">
    <nav class="text-sm text-umber-600" aria-label="Breadcrumb">
      <a href="/" class="hover:underline">Home</a>
      <span class="mx-1">&rsaquo;</span>
      <a href="/guides" class="hover:underline">Guides</a>
      <span class="mx-1">&rsaquo;</span>
      <span>{d.category.replace(/-/g, ' ')}</span>
    </nav>

    <header class="mt-4">
      <h1 class="font-display text-3xl font-semibold tracking-tight text-ink-900 sm:text-4xl">{d.title}</h1>
      <p class="mt-2 text-lg text-umber-600">{d.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-umber-600">
        <span class="inline-flex items-center rounded bg-cream-200 px-2 py-0.5 font-medium capitalize text-ink-900">{d.difficulty}</span>
        {d.estimatedMinutes && <span>{d.estimatedMinutes} min</span>}
        <span>By {d.author}</span>
        <LastUpdated date={d.updatedAt ?? d.publishedAt} />
      </div>
    </header>

    <AffiliateDisclosure />

    <div class="mt-6 leading-7 text-ink-900 [&>h2]:mt-10 [&>h2]:font-display [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:tracking-tight [&>h3]:mt-8 [&>h3]:font-display [&>h3]:text-xl [&>h3]:font-semibold [&>p]:mt-4 [&>ul]:mt-4 [&>ul]:list-disc [&>ul]:pl-5 [&>ol]:mt-4 [&>ol]:list-decimal [&>ol]:pl-5 [&>ul>li]:mt-1 [&>ol>li]:mt-1">
      <Content components={mdxComponents} />
    </div>
  </article>
</BaseLayout>
