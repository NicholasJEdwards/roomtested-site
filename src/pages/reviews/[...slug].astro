---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewStandard from '../../layouts/templates/review-standard.astro';
import ReviewData from '../../layouts/templates/review-data.astro';
import { getRelatedArticles } from '../../lib/links';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews', (e) => !e.data.draft || import.meta.env.DEV);
  return reviews.map((review) => ({ params: { slug: review.id }, props: { review } }));
}

const { review } = Astro.props;
const { Content, headings } = await render(review);
const d = review.data;
const ogImage = `/cards/reviews/${review.id}/og.png`;
const related = await getRelatedArticles(review);

// Dispatch by frontmatter `template`; default review layout otherwise.
const Template = d.template === 'review-data' ? ReviewData : ReviewStandard;
---

<BaseLayout
  title={d.title}
  description={d.description}
  ogType="article"
  ogImage={ogImage}
  publishedAt={d.publishedAt}
  modifiedAt={d.updatedAt}
  author={d.author}
  section={d.category.replace(/-/g, ' ')}
  tags={d.tags}
>
  <Template entry={review} Content={Content} headings={headings} related={related} />
</BaseLayout>
