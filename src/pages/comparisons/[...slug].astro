---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleStandard from '../../layouts/templates/article-standard.astro';
import ComparisonGrid from '../../layouts/templates/comparison-grid.astro';
import { getRelatedArticles } from '../../lib/links';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons', (e) => !e.data.draft || import.meta.env.DEV);
  return comparisons.map((comparison) => ({ params: { slug: comparison.id }, props: { comparison } }));
}

const { comparison } = Astro.props;
const { Content, headings } = await render(comparison);
const d = comparison.data;
const ogImage = `/cards/comparisons/${comparison.id}/og.png`;
const related = await getRelatedArticles(comparison);

// Default to the side-by-side grid; allow opting into the generic layout.
const useGrid = d.template !== 'article-standard';
---

<BaseLayout
  title={d.title}
  description={d.description}
  ogType="article"
  ogImage={ogImage}
  publishedAt={d.publishedAt}
  modifiedAt={d.updatedAt}
  author={d.author}
  section={d.category.replace(/-/g, ' ')}
  tags={d.tags}
>
  {useGrid ? (
    <ComparisonGrid entry={comparison} Content={Content} headings={headings} related={related} />
  ) : (
    <ArticleStandard entry={comparison} Content={Content} headings={headings} related={related} kind="comparison" />
  )}
</BaseLayout>
