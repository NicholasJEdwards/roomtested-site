---
import JsonLd from '../../components/JsonLd.astro';
import { CATEGORIES } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbsLd, itemListLd } from '../../lib/jsonld';
import { getCategoryArticles } from '../../lib/links';
import { getAllProducts } from '../../lib/products';

export async function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category: category.slug }, props: { category } }));
}

const { category } = Astro.props;
const url = `/c/${category.slug}`;
const articles = await getCategoryArticles(category.slug);
const productCount = getAllProducts().filter((p) => p.category === category.slug).length;

// Most-recent update across the category's articles → the "updated" stamp.
const latest = articles.reduce<Date | null>((acc, a) => {
  const d = a.publishedAt;
  return !acc || d > acc ? d : acc;
}, null);

const dateFmt = new Intl.DateTimeFormat('en-GB', { month: 'short', day: 'numeric', year: 'numeric' });
const stampFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

// Filter pills (only the kinds that actually appear, plus "All").
const KINDS: { key: string; label: string }[] = [
  { key: 'all', label: 'All' },
  { key: 'review', label: 'Reviews' },
  { key: 'guide', label: 'Guides' },
  { key: 'comparison', label: 'Comparisons' },
];
const presentKinds = new Set(articles.map((a) => a.kind));
const pills = KINDS.filter((k) => k.key === 'all' || presentKinds.has(k.key as any));
const kindLabel: Record<string, string> = { review: 'review', guide: 'guide', comparison: 'head-to-head' };
---

<BaseLayout
  title={category.name}
  description={`${category.name}: ${category.description} Every product tested in a real room.`}
>
  <JsonLd
    data={[
      breadcrumbsLd([
        { name: 'Home', href: '/' },
        { name: category.name, href: url },
      ]),
      itemListLd(articles.map((a) => ({ name: a.title, url: a.href }))),
    ]}
  />

  <!-- Pillar intro band -->
  <section class="-mx-4 bg-cream-100 px-4 py-12 sm:py-14">
    <div class="mx-auto max-w-3xl">
      <div class="font-data text-xs font-bold uppercase tracking-[0.16em] text-terracotta-600">Category</div>
      <h1 class="mt-3.5 font-display text-[42px] font-semibold leading-[1.1] tracking-tight text-ink-900 sm:text-[56px]">{category.name}</h1>
      <p class="mt-4 max-w-[62ch] font-body text-[17px] leading-[1.58] text-umber-600 sm:text-xl">
        {category.description} Tested in a real room, not a lab — everything here was bought, fitted and lived with before we wrote a word.
      </p>
      <div class="mt-5 flex flex-wrap gap-x-5 gap-y-1.5 font-data text-[11px] uppercase tracking-[0.05em] text-sepia-400">
        <span>{articles.length} {articles.length === 1 ? 'article' : 'articles'}</span>
        {productCount > 0 && <span>{productCount} {productCount === 1 ? 'product' : 'products'} tested</span>}
        {latest && <span>Updated {stampFmt.format(latest)}</span>}
      </div>
    </div>
  </section>

  {articles.length > 0 ? (
    <div class="py-8" data-category-grid>
      <!-- Filter / sort row -->
      <div class="flex flex-wrap items-center gap-2.5 pb-3">
        {pills.map((p) => (
          <button
            type="button"
            data-filter={p.key}
            class:list={[
              'rounded-full px-4 py-2 font-body text-sm font-semibold transition-colors',
              p.key === 'all'
                ? 'bg-ink-900 text-white'
                : 'border border-sepia-200 bg-white text-umber-600 hover:border-pine-700 hover:text-ink-900',
            ]}
            aria-pressed={p.key === 'all' ? 'true' : 'false'}
          >
            {p.label}
          </button>
        ))}
        <span class="ml-auto font-data text-[11px] uppercase tracking-[0.05em] text-sepia-400">Sort: Newest</span>
      </div>

      <!-- Article grid -->
      <ul class="mt-3 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((a, i) => (
          <li data-kind={a.kind}>
            <a
              href={a.href}
              class="group flex h-full flex-col overflow-hidden rounded-xl border border-sepia-200 bg-white transition-colors hover:border-pine-700"
            >
              <div class="relative aspect-[360/210] w-full overflow-hidden bg-cream-200">
                <img
                  src={a.image}
                  alt={a.title}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  class="block h-full w-full object-cover transition-transform group-hover:scale-[1.02]"
                />
                {i === 0 && a.kind === 'review' && a.rating !== undefined && a.rating > 0 && (
                  <span class="absolute left-3.5 top-3.5 rounded-sm bg-ochre-500 px-2 py-1 font-data text-[9px] font-bold uppercase tracking-[0.05em] text-ink-900">
                    Our pick
                  </span>
                )}
              </div>
              <div class="flex flex-1 flex-col gap-2.5 px-[18px] pb-[18px] pt-4">
                <div class="flex items-center gap-2">
                  <span class="flex-1 font-data text-[10px] font-medium uppercase tracking-[0.1em] text-terracotta-600">
                    {category.name} · {kindLabel[a.kind] ?? a.kind}
                  </span>
                  {a.rating !== undefined && a.rating > 0 && (
                    <span class="font-display text-sm font-semibold text-ink-900">{a.rating.toFixed(1)}/10</span>
                  )}
                </div>
                <h2 class="font-display text-[19px] font-semibold leading-[1.28] text-ink-900 group-hover:text-pine-700">{a.title}</h2>
                <div class="mt-auto border-t border-sepia-200 pt-2.5">
                  <span class="font-data text-[11px] tracking-[0.02em] text-umber-600">
                    {a.brand ? `${a.brand} · ` : ''}N. Edwards · {dateFmt.format(a.publishedAt)}
                  </span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-6 hidden text-center font-body text-sm text-umber-600" data-empty>
        No articles match that filter yet.
      </p>
    </div>
  ) : (
    <div class="py-12">
      <p class="font-body text-sm text-umber-600">No posts in this category yet — a test may be running. New posts land here soon.</p>
    </div>
  )}
</BaseLayout>

<script>
  // Client-side filter (progressive enhancement). No-ops without JS — all cards visible.
  for (const grid of document.querySelectorAll<HTMLElement>('[data-category-grid]')) {
    const pills = grid.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const items = grid.querySelectorAll<HTMLElement>('li[data-kind]');
    const empty = grid.querySelector<HTMLElement>('[data-empty]');
    const apply = (key: string) => {
      let shown = 0;
      for (const li of items) {
        const match = key === 'all' || li.dataset.kind === key;
        li.hidden = !match;
        if (match) shown++;
      }
      if (empty) empty.hidden = shown !== 0;
    };
    for (const pill of pills) {
      pill.addEventListener('click', () => {
        for (const p of pills) {
          const active = p === pill;
          p.setAttribute('aria-pressed', active ? 'true' : 'false');
          p.classList.toggle('bg-ink-900', active);
          p.classList.toggle('text-white', active);
          p.classList.toggle('border', !active);
          p.classList.toggle('border-sepia-200', !active);
          p.classList.toggle('bg-white', !active);
          p.classList.toggle('text-umber-600', !active);
        }
        apply(pill.dataset.filter ?? 'all');
      });
    }
  }
</script>
