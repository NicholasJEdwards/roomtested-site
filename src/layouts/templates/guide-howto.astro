---
// HowTo-led guide layout (default for guides WITH steps, or template: "guide-howto").
// Renders the numbered StepList + HowTo JSON-LD up top, then the body for the prose.
// Emits articleLd + breadcrumbsLd (StepList adds howToLd itself).
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AuthorStrip from '../../components/AuthorStrip.astro';
import Faq from '../../components/Faq.astro';
import JsonLd from '../../components/JsonLd.astro';
import KeySpecs from '../../components/KeySpecs.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import StepList from '../../components/StepList.astro';
import Toc from '../../components/Toc.astro';
import { mdxComponents } from '../../lib/mdx-components';
import { articleLd, breadcrumbsLd } from '../../lib/jsonld';
import type { ArticleRef } from '../../lib/links';

interface Props {
  entry: CollectionEntry<'guides'>;
  Content: any;
  headings: MarkdownHeading[];
  related: ArticleRef[];
}

const { entry, Content, headings, related } = Astro.props;
const d = entry.data;
const url = `/guides/${entry.id}`;
const ogImage = `/cards/guides/${entry.id}/og.png`;
// HowTo totalTime from estimatedMinutes, as an ISO-8601 duration.
const totalTime = d.estimatedMinutes ? `PT${d.estimatedMinutes}M` : undefined;
const categoryLabel = d.category.replace(/-/g, ' ');
// Outlined meta chips (mono label + value) — only the ones we actually have.
const chips: { label: string; value: string }[] = [
  { label: 'Difficulty', value: d.difficulty },
  ...(d.estimatedMinutes ? [{ label: 'Time', value: `${d.estimatedMinutes} min` }] : []),
  ...(d.steps && d.steps.length > 0 ? [{ label: 'Steps', value: String(d.steps.length) }] : []),
];
---

<JsonLd
  data={[
    articleLd({
      title: d.title,
      description: d.description,
      url,
      publishedAt: d.publishedAt,
      updatedAt: d.updatedAt,
      author: d.author,
      image: ogImage,
    }),
    breadcrumbsLd([
      { name: 'Home', href: '/' },
      { name: 'Guides', href: '/guides' },
      { name: d.title, href: url },
    ]),
  ]}
/>

<article class="mx-auto max-w-3xl py-12">
  <nav class="text-sm text-umber-600" aria-label="Breadcrumb">
    <a href="/" class="hover:underline">Home</a>
    <span class="mx-1">&rsaquo;</span>
    <a href="/guides" class="hover:underline">Guides</a>
    <span class="mx-1">&rsaquo;</span>
    <a href={`/c/${d.category}`} class="hover:underline">{d.category.replace(/-/g, ' ')}</a>
  </nav>

  <header class="mt-5">
    <div class="font-data text-[13px] font-medium uppercase tracking-[0.12em] text-terracotta-600">{categoryLabel} · Guide</div>
    <h1 class="mt-2 font-display text-[28px] font-semibold leading-[1.2] tracking-tight text-ink-900 sm:text-[40px] sm:leading-[1.18]">{d.title}</h1>
    <p class="mt-3 font-body text-lg leading-[1.55] text-umber-600">{d.description}</p>
    <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-3">
      <AuthorStrip author={d.author} credential="Hands-on walkthrough" inline />
      <div class="font-data text-[11px] uppercase tracking-[0.05em] text-umber-600">
        <LastUpdated date={d.updatedAt ?? d.publishedAt} label="Updated" compact />
      </div>
    </div>
    <div class="mt-4 flex flex-wrap gap-2.5">
      {chips.map((c) => (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-sepia-200 bg-white px-3 py-1.5 font-data text-[11px] tracking-[0.03em]">
          <span class="uppercase text-sepia-400">{c.label}</span>
          <span class="font-medium capitalize text-ink-900">{c.value}</span>
        </span>
      ))}
    </div>
  </header>

  <AffiliateDisclosure />

  <Toc headings={headings} title="The steps" numberPrefix="STEP " />

  <StepList steps={d.steps} name={d.title} totalTime={totalTime} />

  <div class="mt-6 leading-7 text-ink-900 [&>h2]:mt-10 [&>h2]:font-display [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:tracking-tight [&>h3]:mt-8 [&>h3]:font-display [&>h3]:text-xl [&>h3]:font-semibold [&>p]:mt-4 [&>ul]:mt-4 [&>ul]:list-disc [&>ul]:pl-5 [&>ol]:mt-4 [&>ol]:list-decimal [&>ol]:pl-5 [&>ul>li]:mt-1 [&>ol>li]:mt-1">
    <Content components={mdxComponents} />
  </div>

  <KeySpecs specs={d.keySpecs} />

  <Faq faq={d.faq} />

  <AuthorStrip author={d.author} />

  <RelatedArticles entries={related} />
</article>
