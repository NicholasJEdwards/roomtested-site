---
// Default review layout: breadcrumb · header · Verdict (top) · Toc · body · ProsCons
// · KeySpecs · Faq · AuthorStrip · RelatedArticles · disclosure. Emits reviewLd +
// productLd + breadcrumbsLd. Driven entirely by frontmatter; every optional section
// no-ops when its field is absent (the draft NIC review still renders cleanly).
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AuthorStrip from '../../components/AuthorStrip.astro';
import Faq from '../../components/Faq.astro';
import JsonLd from '../../components/JsonLd.astro';
import KeySpecs from '../../components/KeySpecs.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import PriceWidget from '../../components/mdx/PriceWidget.astro';
import ProductMedia from '../../components/ProductMedia.astro';
import ProsCons from '../../components/mdx/ProsCons.astro';
import RatingBadge from '../../components/mdx/RatingBadge.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import Toc from '../../components/Toc.astro';
import Verdict from '../../components/Verdict.astro';
import { mdxComponents } from '../../lib/mdx-components';
import { breadcrumbsLd, productLd, reviewLd } from '../../lib/jsonld';
import type { ArticleRef } from '../../lib/links';
import { getProduct } from '../../lib/products';

interface Props {
  entry: CollectionEntry<'reviews'>;
  Content: any;
  headings: MarkdownHeading[];
  related: ArticleRef[];
}

const { entry, Content, headings, related } = Astro.props;
const d = entry.data;
const url = `/reviews/${entry.id}`;
const product = getProduct(d.productId);
const hasProsCons = d.pros.length > 0 || d.cons.length > 0;
const categoryLabel = d.category.replace(/-/g, ' ');
// Hero image provenance: a stored product image is a manufacturer/store listing image
// unless we know it's our own (no 'own' photos are wired yet → honest 'listing' caption).
const heroSrc = d.heroImage ?? product?.image;
---

<JsonLd
  data={[
    reviewLd({
      title: d.title,
      description: d.description,
      url,
      publishedAt: d.publishedAt,
      updatedAt: d.updatedAt,
      author: d.author,
      productName: product?.name ?? d.title,
      brand: d.brand,
      rating: d.rating,
    }),
    productLd({
      name: product?.name ?? d.title,
      brand: d.brand,
      image: product?.image,
      url,
      priceFromGBP: product?.priceFromGBP,
      priceCheckedAt: product?.priceCheckedAt,
      ...(d.rating > 0 ? { aggregateRating: { ratingValue: d.rating, reviewCount: 1 } } : {}),
    }),
    breadcrumbsLd([
      { name: 'Home', href: '/' },
      { name: 'Reviews', href: '/reviews' },
      { name: d.title, href: url },
    ]),
  ]}
/>

<article class="mx-auto max-w-3xl py-12">
  <nav class="text-sm text-umber-600" aria-label="Breadcrumb">
    <a href="/" class="hover:underline">Home</a>
    <span class="mx-1">&rsaquo;</span>
    <a href="/reviews" class="hover:underline">Reviews</a>
    <span class="mx-1">&rsaquo;</span>
    <a href={`/c/${d.category}`} class="hover:underline">{d.category.replace(/-/g, ' ')}</a>
  </nav>

  <header class="mt-5">
    <div class="font-data text-[13px] font-medium uppercase tracking-[0.12em] text-terracotta-600">{categoryLabel} · Review</div>
    <h1 class="mt-2 font-display text-[28px] font-semibold leading-[1.2] tracking-tight text-ink-900 sm:text-[40px] sm:leading-[1.18]">{d.title}</h1>
    <p class="mt-3 font-body text-lg leading-[1.55] text-umber-600">{d.description}</p>
    <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-3">
      <AuthorStrip author={d.author} credential="Bench testing · hands-on" inline />
      {d.rating > 0 && <RatingBadge score={d.rating} max={5} inline />}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-data text-[11px] uppercase tracking-[0.05em] text-umber-600">
        <LastUpdated date={d.publishedAt} label="Published" compact />
        {d.updatedAt && <LastUpdated date={d.updatedAt} label="Updated" compact />}
        <LastUpdated date={d.lastTested} label="Tested" compact />
      </div>
    </div>
  </header>

  <AffiliateDisclosure />

  {heroSrc && (
    <ProductMedia
      kind="listing"
      src={heroSrc}
      alt={product?.name ?? d.title}
      ratio="3/2"
      priority
      class="mt-6"
    />
  )}

  {d.rating > 0 && <Verdict rating={d.rating} max={5} oneLiner={d.description} pros={d.pros} cons={d.cons} />}

  <Toc headings={headings} />

  <div class="mt-6 font-body leading-[1.65] text-ink-900 [&>h2]:mt-10 [&>h2]:font-display [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:tracking-tight [&>h3]:mt-8 [&>h3]:font-display [&>h3]:text-xl [&>h3]:font-semibold [&>p]:mt-4 [&>ul]:mt-4 [&>ul]:list-disc [&>ul]:pl-5 [&>ol]:mt-4 [&>ol]:list-decimal [&>ol]:pl-5 [&>ul>li]:mt-1 [&>ol>li]:mt-1">
    <Content components={mdxComponents} />
  </div>

  {hasProsCons && <ProsCons pros={d.pros} cons={d.cons} />}

  <KeySpecs specs={d.keySpecs} />

  {product && <PriceWidget productId={d.productId} compareStore="ebay" />}

  <Faq faq={d.faq} />

  <RelatedArticles entries={related} />

  <AuthorStrip author={d.author} />
</article>
