---
// "On this page" jump list from Astro's render() `headings`. White card, sepia hairline,
// mono Bold umber kicker, pink mono numbers (01, 02 …), Nunito-SemiBold ink labels.
// Shows h2/h3 only; no-ops when there are too few headings to be useful.
import type { MarkdownHeading } from 'astro';

interface Props {
  headings?: MarkdownHeading[];
  title?: string;
  /** Number prefix, e.g. "STEP " for guides → "STEP 1". Default zero-padded "01". */
  numberPrefix?: string;
}

const { headings = [], title = 'On this page', numberPrefix } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const has = items.length >= 2;
const num = (i: number) =>
  numberPrefix ? `${numberPrefix}${i + 1}` : String(i + 1).padStart(2, '0');
---

{has && (
  <nav class="not-prose my-8 rounded-md border border-sepia-200 bg-white p-5" aria-label={title}>
    <div class="font-data text-[11px] font-bold uppercase tracking-[0.14em] text-umber-600">{title}</div>
    <ol class="mt-3 space-y-2">
      {items.map((h, i) => (
        <li class:list={['flex gap-3', h.depth === 3 && 'pl-5']}>
          <span class="shrink-0 font-data text-xs font-medium text-terracotta-600">{num(i)}</span>
          <a
            href={`#${h.slug}`}
            class="font-body text-[15px] font-semibold leading-snug text-ink-900 underline-offset-2 transition-colors hover:text-pine-700 hover:underline"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
