---
// The numeric score stamp — never star rows. Matches the RatingBadge swatch (32:4):
// circular, white fill, 2px pink border for a positive pick (crimson for a "skip"),
// Rubik-Bold score + "OUT OF N" mono. Also renders inline (no circle) as "8.4 / 10".
interface Props {
  score: number;
  max?: number;
  tone?: 'positive' | 'skip';
  /** Inline pill (no circle) for bylines / cards. */
  inline?: boolean;
}

const { score, max = 10, tone = 'positive', inline = false } = Astro.props;
const clamped = Math.max(0, Math.min(score, max));
const ringClass = tone === 'skip' ? 'border-brick-600' : 'border-terracotta-600';
---

{inline ? (
  <span class="inline-flex items-baseline gap-1 font-display text-base font-bold text-ink-900" aria-label={`Rated ${clamped.toFixed(1)} out of ${max}`}>
    {clamped.toFixed(1)}<span class="font-data text-[11px] font-medium text-umber-600">/ {max}</span>
  </span>
) : (
  <div class="not-prose my-6 inline-flex">
    <div
      class:list={['flex h-[120px] w-[120px] flex-col items-center justify-center gap-0.5 rounded-full border-2 bg-white text-center', ringClass]}
      role="img"
      aria-label={`Rated ${clamped.toFixed(1)} out of ${max}`}
    >
      <span class="font-display text-[40px] font-bold leading-none text-ink-900">{clamped.toFixed(1)}</span>
      <span class="font-data text-[10px] font-medium uppercase tracking-[0.05em] text-umber-600">out of {max}</span>
    </div>
  </div>
)}
