---
interface Props {
  rating: number;
  max?: number;
  label?: string;
}

const { rating, max = 5, label } = Astro.props;
const clamped = Math.max(0, Math.min(rating, max));
const normalized = clamped / max;

const tone: 'pine' | 'brick' | 'neutral' =
  normalized >= 0.8 ? 'pine' : normalized < 0.6 ? 'brick' : 'neutral';

const ringClass =
  tone === 'pine' ? 'border-pine-700' : tone === 'brick' ? 'border-brick-600' : 'border-sepia-400';
const ribbonBgClass = tone === 'pine' ? 'bg-pine-700' : tone === 'brick' ? 'bg-brick-600' : '';
const defaultLabel = tone === 'pine' ? "Editor's Pick" : tone === 'brick' ? 'Skip' : null;
const resolvedLabel = label ?? defaultLabel;
---

<div class="not-prose my-6 inline-flex">
  <div
    class={`relative flex h-32 w-32 flex-col items-center justify-center rounded-full border-2 bg-cream-50 text-center ${ringClass}`}
    role="img"
    aria-label={`Rated ${clamped.toFixed(1)} out of ${max}${resolvedLabel ? `. ${resolvedLabel}.` : ''}`}
  >
    <div class="font-display text-3xl font-semibold leading-none text-ink-900">{clamped.toFixed(1)}</div>
    <div class="mt-1 font-data text-[10px] uppercase tracking-wider text-umber-600">out of {max}</div>
    {resolvedLabel && ribbonBgClass && (
      <div
        class={`absolute -bottom-[10px] rounded-sm px-3 py-1 font-data text-[10px] uppercase tracking-widest text-cream-50 ${ribbonBgClass}`}
      >
        {resolvedLabel}
      </div>
    )}
  </div>
</div>
