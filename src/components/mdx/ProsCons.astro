---
// Two-column strengths/weaknesses summary (standalone, or inside Verdict / BestOfPick).
// Cons are mandatory on every review and pick. Markers carry the meaning, never colour
// alone (accessibility): pros = ink "+", cons = crimson "–", with "PROS"/"CONS" labels.
interface Props {
  pros: string[];
  cons: string[];
  proLabel?: string;
  conLabel?: string;
}

const { pros, cons, proLabel = 'Pros', conLabel = 'Cons' } = Astro.props;
---

<div class="not-prose my-8 grid gap-6 rounded-md border border-sepia-200 bg-white p-5 sm:grid-cols-2 sm:gap-8">
  <div class="flex flex-col gap-2">
    <div class="font-data text-[11px] font-bold uppercase tracking-[0.1em] text-ink-900">{proLabel}</div>
    <ul class="flex flex-col gap-1.5">
      {pros.map((p) => (
        <li class="flex gap-2 text-sm">
          <span class="w-3 shrink-0 font-body font-bold text-ink-900" aria-hidden="true">+</span>
          <span class="flex-1 font-body leading-[1.45] text-umber-600">{p}</span>
        </li>
      ))}
    </ul>
  </div>
  <div class="flex flex-col gap-2">
    <div class="font-data text-[11px] font-bold uppercase tracking-[0.1em] text-brick-600">{conLabel}</div>
    <ul class="flex flex-col gap-1.5">
      {cons.map((c) => (
        <li class="flex gap-2 text-sm">
          <span class="w-3 shrink-0 font-body font-bold text-brick-600" aria-hidden="true">&ndash;</span>
          <span class="flex-1 font-body leading-[1.45] text-umber-600">{c}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
