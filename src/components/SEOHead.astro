---
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  // Article OpenGraph metadata — only emitted when ogType === 'article'.
  publishedAt?: Date;
  modifiedAt?: Date;
  author?: string;
  section?: string;
  tags?: string[];
  // Set true to ask crawlers not to index this page (e.g. /style-guide).
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  ogImage,
  ogType = 'website',
  publishedAt,
  modifiedAt,
  author,
  section,
  tags,
  noindex = false,
} = Astro.props;

const fullTitle = title === SITE.name ? `${title} — ${SITE.tagline}` : `${title} — ${SITE.name}`;
const ogImageUrl = ogImage ? new URL(ogImage, SITE.url).toString() : undefined;
const isArticle = ogType === 'article';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.defaultAuthor} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content="en_GB" />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

{isArticle && publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
{isArticle && (modifiedAt ?? publishedAt) && (
  <meta property="article:modified_time" content={(modifiedAt ?? publishedAt)!.toISOString()} />
)}
{isArticle && author && <meta property="article:author" content={author} />}
{isArticle && section && <meta property="article:section" content={section} />}
{isArticle && tags?.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
