---
// THE VERDICT box — the top-of-review TL;DR a skimmer (or an LLM) lifts. One per page.
// Matches the VerdictBox swatch (33:4): pink "THE VERDICT" kicker, big Rubik score with
// "/ N" beneath, one-line pitch, then a two-column "BUY IT IF" (ink +) / "SKIP IT IF"
// (crimson –) split. Pros/cons are optional → degrades to score + one-liner (the compact
// variant used by specs-led / comparison templates).
interface Props {
  rating?: number;
  /** Denominator shown after the score (review ratings are /5; design swatch shows /10). */
  max?: number;
  oneLiner: string;
  pros?: string[];
  cons?: string[];
  proLabel?: string;
  conLabel?: string;
}

const {
  rating,
  max = 10,
  oneLiner,
  pros,
  cons,
  proLabel = 'Buy it if',
  conLabel = 'Skip it if',
} = Astro.props;
const hasPros = Array.isArray(pros) && pros.length > 0;
const hasCons = Array.isArray(cons) && cons.length > 0;
const hasSplit = hasPros || hasCons;
---

<aside
  class="not-prose my-8 flex flex-col gap-3.5 rounded-md border border-sepia-200 bg-cream-100 p-5"
  aria-label="The verdict"
>
  <div class="font-data text-[11px] font-bold uppercase tracking-[0.14em] text-terracotta-600">The verdict</div>

  <div class="flex items-center gap-4">
    {rating !== undefined && (
      <div class="flex shrink-0 flex-col items-center leading-none">
        <span class="font-display text-[44px] font-bold text-ink-900">{rating.toFixed(1)}</span>
        <span class="mt-0.5 font-data text-[11px] font-medium text-umber-600">/ {max}</span>
      </div>
    )}
    <p class="flex-1 font-display text-lg font-semibold leading-snug text-ink-900">{oneLiner}</p>
  </div>

  {hasSplit && (
    <div class="grid grid-cols-2 gap-5 pt-0.5">
      <div class="flex flex-col gap-1.5">
        <div class="font-data text-[11px] font-bold uppercase tracking-[0.1em] text-ink-900">{proLabel}</div>
        {hasPros
          ? pros!.map((p) => (
              <div class="flex gap-1.5 text-sm">
                <span class="w-3 shrink-0 font-body font-bold text-ink-900" aria-hidden="true">+</span>
                <span class="flex-1 font-body leading-[1.4] text-umber-600">{p}</span>
              </div>
            ))
          : <span class="font-data text-xs text-sepia-400">—</span>}
      </div>
      <div class="flex flex-col gap-1.5">
        <div class="font-data text-[11px] font-bold uppercase tracking-[0.1em] text-brick-600">{conLabel}</div>
        {hasCons
          ? cons!.map((c) => (
              <div class="flex gap-1.5 text-sm">
                <span class="w-3 shrink-0 font-body font-bold text-brick-600" aria-hidden="true">&ndash;</span>
                <span class="flex-1 font-body leading-[1.4] text-umber-600">{c}</span>
              </div>
            ))
          : <span class="font-data text-xs text-sepia-400">—</span>}
      </div>
    </div>
  )}
</aside>
