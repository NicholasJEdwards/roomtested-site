---
import { SITE } from '../consts';

// Global nav — matches every template frame's GlobalNav: white bg, Rubik-SemiBold
// wordmark, Rubik-Medium ink links (Reviews / Guides / Comparisons / About), bottom
// hairline. Sticky + accessible (active state, focus). Mobile collapses to wordmark + ≡
// (a details/summary disclosure, no JS).
const nav: { label: string; href: string }[] = [
  { label: 'Reviews', href: '/reviews' },
  { label: 'Guides', href: '/guides' },
  { label: 'Comparisons', href: '/comparisons' },
  { label: 'About', href: '/about' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="sticky top-0 z-30 border-b border-sepia-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/85">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-8 px-4 py-4 sm:py-5">
    <a href="/" class="font-display text-[22px] font-semibold leading-none tracking-tight text-ink-900 transition-colors hover:text-pine-700">
      {SITE.name}
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden sm:block">
      <ul class="flex items-center gap-7">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'relative font-display text-[15px] font-medium transition-colors',
                isActive(item.href)
                  ? 'text-ink-900 after:absolute after:inset-x-0 after:-bottom-[18px] after:h-[2px] after:bg-ink-900'
                  : 'text-ink-900/85 hover:text-ink-900',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile nav -->
    <details class="relative sm:hidden [&[open]>summary_.menu-x]:block [&[open]>summary_.menu-bars]:hidden">
      <summary class="flex cursor-pointer list-none items-center text-ink-900 [&::-webkit-details-marker]:hidden" aria-label="Menu">
        <span class="menu-bars font-data text-2xl leading-none" aria-hidden="true">&#8801;</span>
        <span class="menu-x hidden font-data text-2xl leading-none" aria-hidden="true">&times;</span>
      </summary>
      <nav aria-label="Primary" class="absolute right-0 top-[calc(100%+12px)] w-44 rounded-md border border-sepia-200 bg-white p-2 shadow-sm">
        <ul class="flex flex-col">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block rounded px-3 py-2 font-display text-[15px] font-medium transition-colors hover:bg-cream-100',
                  isActive(item.href) ? 'text-ink-900' : 'text-ink-900/85',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>
