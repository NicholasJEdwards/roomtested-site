---
// Numbered steps + HowTo JSON-LD. No-ops when steps is absent/empty.
import { howToLd } from '../lib/jsonld';
import JsonLd from './JsonLd.astro';

interface Props {
  steps?: { name: string; text: string }[];
  /** Name for the HowTo schema (usually the article title). */
  name?: string;
  /** ISO-8601 duration for totalTime, e.g. "PT10M". */
  totalTime?: string;
  title?: string;
}

const { steps, name, totalTime, title = 'Step by step' } = Astro.props;
const has = Array.isArray(steps) && steps.length > 0;
---

{has && (
  <section class="not-prose my-10" aria-label={title}>
    <JsonLd data={howToLd({ name: name ?? title, steps: steps!, totalTime })} />
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink-900">{title}</h2>
    <ol class="mt-6 space-y-5">
      {steps!.map((step, i) => (
        <li class="flex gap-4">
          <span
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-terracotta-600 font-data text-sm font-semibold text-cream-50"
            aria-hidden="true"
          >
            {i + 1}
          </span>
          <div class="flex-1 pt-0.5">
            <div class="font-display text-lg font-semibold leading-snug text-ink-900">{step.name}</div>
            <p class="mt-1 leading-7 text-umber-600">{step.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}
