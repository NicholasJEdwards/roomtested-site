---
// Byline / author card — who tested it. Circular ink-900 monogram (white Rubik-SemiBold
// initials) + Rubik-SemiBold name + a mono credential stamp. Two forms: the compact
// inline byline (top of a review, optionally paired with a RatingBadge) and the expanded
// card (foot of long posts) with bio + method links. Reinforces "tested in a real room"
// (E-E-A-T). Load-bearing for LLM citation.
import { SITE } from '../consts';

interface Props {
  author?: string;
  /** Mono stamp under the name, e.g. "Bench testing · 3 weeks hands-on". */
  credential?: string;
  /** Compact byline (no bio/links, no card chrome) — used at the top of a review. */
  inline?: boolean;
  class?: string;
}

const {
  author = SITE.defaultAuthor,
  credential = 'Tested in a real room',
  inline = false,
  class: className,
} = Astro.props;
const initials = author
  .split(/\s+/)
  .map((part) => part[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

{inline ? (
  <div class:list={['not-prose flex items-center gap-3', className]}>
    <span
      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-ink-900 font-display text-sm font-semibold text-white"
      aria-hidden="true"
    >
      {initials}
    </span>
    <div class="flex flex-col">
      <span class="font-display text-[15px] font-semibold leading-tight text-ink-900">{author}</span>
      <span class="font-data text-[11px] tracking-[0.02em] text-umber-600">{credential}</span>
    </div>
  </div>
) : (
  <aside
    class:list={['not-prose my-10 flex items-start gap-4 rounded-md border border-sepia-200 bg-cream-100 p-5', className]}
    aria-label="About the author"
  >
    <span
      class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-ink-900 font-display text-base font-semibold text-white"
      aria-hidden="true"
    >
      {initials}
    </span>
    <div class="flex-1">
      <div class="font-display text-base font-semibold text-ink-900">{author}</div>
      <p class="mt-1 font-body text-sm leading-relaxed text-umber-600">
        Tested in a real room — long enough that the honeymoon phase has ended — before it's
        recommended.
      </p>
      <div class="mt-3 flex flex-wrap gap-4 font-data text-[11px] font-semibold uppercase tracking-[0.14em]">
        <a href="/about" class="text-pine-700 transition-colors hover:text-ink-900">About</a>
        <a href="/how-we-test" class="text-pine-700 transition-colors hover:text-ink-900">How we test</a>
      </div>
    </div>
  </aside>
)}
