---
// FAQ list + its FAQPage JSON-LD. Matches the FaqItem swatch (34:24): each item is a
// white bordered card with a Rubik-SemiBold question, a pink mono +/– toggle glyph, and
// a Nunito-Sans answer. Native <details> = accessible + keyboard-operable with no JS;
// the glyph flips +/– via CSS on [open]. No-ops entirely when faq is absent/empty.
import { faqLd } from '../lib/jsonld';
import JsonLd from './JsonLd.astro';

interface Props {
  faq?: { q: string; a: string }[];
  title?: string;
}

const { faq, title = 'Frequently asked' } = Astro.props;
const has = Array.isArray(faq) && faq.length > 0;
---

{has && (
  <section class="not-prose my-10" aria-label={title}>
    <JsonLd data={faqLd(faq!)} />
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink-900">{title}</h2>
    <div class="mt-6 space-y-3">
      {faq!.map((item) => (
        <details class="group rounded-md border border-sepia-200 bg-white px-[18px] py-4 [&[open]>summary_.faq-glyph]:before:content-['–'] [&:not([open])>summary_.faq-glyph]:before:content-['+']">
          <summary class="flex cursor-pointer list-none items-start gap-2.5 [&::-webkit-details-marker]:hidden">
            <span class="flex-1 font-display text-[15px] font-semibold leading-[1.35] text-ink-900">{item.q}</span>
            <span class="faq-glyph h-5 w-3.5 shrink-0 font-data text-base font-bold leading-tight text-terracotta-600 before:block" aria-hidden="true"></span>
          </summary>
          <p class="mt-2 font-body text-sm leading-[1.55] text-umber-600">{item.a}</p>
        </details>
      ))}
    </div>
  </section>
)}
